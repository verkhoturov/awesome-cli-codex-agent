{
  "name": "awesome-cli-codex-agent",
  "version": "1.0.0",
  "description": "Interactive Codex client powered by Codex App Server",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/verkhoturov/awesome-cli-codex-agent.git"
  },
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "custom-codex-agent": "dist/index.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit && biome check",
    "dev": "tsx src/index.ts",
    "resume": "node dist/index.js --resume",
    "start": "node dist/index.js",
    "format": "biome format --write"
  },
  "dependencies": {
    "ink": "^4.1.0",
    "meow": "^11.0.0",
    "react": "^18.2.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.21.0",
    "@babel/preset-react": "^7.18.6",
    "@biomejs/biome": "2.2.0",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "chalk": "^5.2.0",
    "import-jsx": "^5.0.0",
    "ink-testing-library": "^3.0.0"
  },
  "babel": {
    "presets": [
      "@babel/preset-react"
    ]
  }
}
