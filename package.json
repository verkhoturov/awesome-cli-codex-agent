{
  "name": "awesome-cli-codex-agent",
  "version": "1.0.0",
  "description": "Interactive Codex client powered by Codex App Server",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/verkhoturov/awesome-cli-codex-agent.git"
  },
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "dist/app/index.js",
  "bin": {
    "custom-codex-agent": "dist/app/index.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc && tsc-alias",
    "check": "tsc --noEmit && biome check",
    "dev": "tsx src/app/index.ts",
    "resume": "node dist/app/index.js --resume",
    "start": "node dist/app/index.js",
    "format": "biome format --write"
  },
  "dependencies": {
    "@inkjs/ui": "2.0.0",
    "ink": "7.1.0",
    "react": "19.2.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@types/node": "^26.0.0",
    "@types/react": "19.2.17",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
